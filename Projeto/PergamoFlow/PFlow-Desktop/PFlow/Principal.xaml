<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PFlow_Desktop.Principal">

    <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center">

        <Label Text="Sistema PFlow"
               FontSize="32"
               FontAttributes="Bold"
               HorizontalOptions="Center" />

        <Button Text="Lançar Notas"
                Clicked="OnLancarNotasClicked"
                HeightRequest="60"
                WidthRequest="250"
                FontSize="18"
                CornerRadius="10"
                HorizontalOptions="Center" />

    </VerticalStackLayout>
</ContentPage>